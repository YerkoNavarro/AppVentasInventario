<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="520.0" prefWidth="640.0" styleClass="panel-root" stylesheets="@css/panel-productos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistema.puntoventas.controller.moduloProductos.PanelRegistrarCategoriaController">
    <children>
        <Label layoutX="330.0" layoutY="58.0" styleClass="field-label" text="Nombre" />
        <TextField fx:id="txtNombre" layoutX="80.0" layoutY="52.0" prefWidth="240.0" promptText="Nombre de la categoria" styleClass="field" />

        <Label layoutX="330.0" layoutY="136.0" styleClass="field-label" text="Descripcion" />
        <TextField fx:id="txtDescripcion" layoutX="80.0" layoutY="130.0" prefWidth="240.0" promptText="Descripcion" styleClass="field" />

        <CheckBox fx:id="chkActiva" layoutX="80.0" layoutY="205.0" text="Categoria activa" />

        <Label fx:id="lblEstado" layoutX="80.0" layoutY="260.0" prefHeight="32.0" prefWidth="480.0" styleClass="status" text="Listo para registrar" />
        <Button fx:id="btnRegistrar" layoutX="80.0" layoutY="320.0" mnemonicParsing="false" onAction="#registrarCategoria" styleClass="btn-primary" text="Registrar" />
        <Button fx:id="btnCancelar" layoutX="210.0" layoutY="320.0" mnemonicParsing="false" onAction="#cancelar" styleClass="btn-secondary" text="Cancelar" />
    </children>
</AnchorPane>