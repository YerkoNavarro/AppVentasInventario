<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="1080.0" prefWidth="1920.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistema.puntoventas.controller.PanelPrincipalEstadisticasController">
   <children>
      <ScrollPane prefHeight="1080.0" prefWidth="1920.0" style="-fx-background-color: transparent; -fx-padding: 0;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <content>
            <Pane prefHeight="1200.0" prefWidth="1920.0" styleClass="panel-root" stylesheets="@css/panel-productos.css">
               <children>
                  <!-- TÍTULO PRINCIPAL -->
                  <Label layoutX="40.0" layoutY="25.0" styleClass="title" stylesheets="@css/panel-productos.css" text="Estadísticas del Negocio">
                     <font>
                        <Font name="Arial Black" size="28.0" />
                     </font>
                  </Label>

                  <!-- TARJETAS KPI PRINCIPALES -->
                  <HBox layoutX="40.0" layoutY="80.0" prefHeight="160.0" prefWidth="1800.0" spacing="20.0">
                     <children>
                        <!-- Ingresos Totales -->
                        <Pane prefHeight="160.0" prefWidth="320.0" styleClass="card-kpi-blue" stylesheets="@css/PanelPrincipalVista.css">
                           <children>
                              <Label layoutX="25.0" layoutY="15.0" text="Ingresos Totales" textFill="WHITE">
                                 <font>
                                    <Font name="Arial" size="14.0" />
                                 </font>
                              </Label>
                              <Label fx:id="lblIngresosTotales" layoutX="25.0" layoutY="55.0" text="₡0.00" textFill="WHITE">
                                 <font>
                                    <Font name="Arial Black" size="32.0" />
                                 </font>
                              </Label>
                              <Label layoutX="25.0" layoutY="115.0" text="Últimas 24 horas" textFill="#e0e7ff">
                                 <font>
                                    <Font name="Arial" size="11.0" />
                                 </font>
                              </Label>
                           </children>
                        </Pane>

                        <!-- Total Ventas -->
                        <Pane prefHeight="160.0" prefWidth="320.0" styleClass="card-kpi-green" stylesheets="@css/PanelPrincipalVista.css">
                           <children>
                              <Label layoutX="25.0" layoutY="15.0" text="Total de Ventas" textFill="WHITE">
                                 <font>
                                    <Font name="Arial" size="14.0" />
                                 </font>
                              </Label>
                              <Label fx:id="lblTotalVentas" layoutX="25.0" layoutY="55.0" text="0" textFill="WHITE">
                                 <font>
                                    <Font name="Arial Black" size="32.0" />
                                 </font>
                              </Label>
                              <Label layoutX="25.0" layoutY="115.0" text="Transacciones completadas" textFill="#dcfce7">
                                 <font>
                                    <Font name="Arial" size="11.0" />
                                 </font>
                              </Label>
                           </children>
                        </Pane>

                        <!-- Ticket Promedio -->
                        <Pane prefHeight="160.0" prefWidth="320.0" styleClass="card-kpi-yellow" stylesheets="@css/PanelPrincipalVista.css">
                           <children>
                              <Label layoutX="25.0" layoutY="15.0" text="Ticket Promedio" textFill="WHITE">
                                 <font>
                                    <Font name="Arial" size="14.0" />
                                 </font>
                              </Label>
                              <Label fx:id="lblTicketPromedio" layoutX="25.0" layoutY="55.0" text="₡0.00" textFill="WHITE">
                                 <font>
                                    <Font name="Arial Black" size="32.0" />
                                 </font>
                              </Label>
                              <Label layoutX="25.0" layoutY="115.0" text="Promedio por venta" textFill="#fef3c7">
                                 <font>
                                    <Font name="Arial" size="11.0" />
                                 </font>
                              </Label>
                           </children>
                        </Pane>

                        <!-- Productos Vendidos -->
                        <Pane prefHeight="160.0" prefWidth="320.0" styleClass="card-kpi-red" stylesheets="@css/PanelPrincipalVista.css">
                           <children>
                              <Label layoutX="25.0" layoutY="15.0" text="Productos Vendidos" textFill="WHITE">
                                 <font>
                                    <Font name="Arial" size="14.0" />
                                 </font>
                              </Label>
                              <Label fx:id="lblProductosVendidos" layoutX="25.0" layoutY="55.0" text="0" textFill="WHITE">
                                 <font>
                                    <Font name="Arial Black" size="32.0" />
                                 </font>
                              </Label>
                              <Label layoutX="25.0" layoutY="115.0" text="Unidades totales" textFill="#fee2e2">
                                 <font>
                                    <Font name="Arial" size="11.0" />
                                 </font>
                              </Label>
                           </children>
                        </Pane>
                     </children>
                  </HBox>

                  <!-- SEGUNDO NIVEL: PRODUCTOS TOP Y USUARIOS TOP -->
                  <Label layoutX="40.0" layoutY="270.0" styleClass="subtitle" text="Análisis de Rendimiento" textFill="#607399">
                     <font>
                        <Font name="Arial Black" size="18.0" />
                     </font>
                  </Label>

                  <HBox layoutX="40.0" layoutY="310.0" prefHeight="400.0" prefWidth="1800.0" spacing="20.0">
                     <!-- PRODUCTOS MÁS VENDIDOS -->
                     <Pane styleClass="card" stylesheets="@css/panel-productos.css" prefHeight="400.0" prefWidth="880.0">
                        <children>
                           <Label layoutX="25.0" layoutY="15.0" text="Top 10 Productos Más Vendidos" textFill="#274f8d">
                              <font>
                                 <Font name="Arial Black" size="16.0" />
                              </font>
                           </Label>
                           <VBox fx:id="vboxProductosTop" layoutX="25.0" layoutY="50.0" prefHeight="335.0" prefWidth="830.0" spacing="8.0">
                              <children>
                                 <!-- Los items se cargarán dinámicamente -->
                              </children>
                           </VBox>
                        </children>
                     </Pane>

                     <!-- INFORMACIÓN ADICIONAL -->
                     <VBox prefHeight="400.0" prefWidth="880.0" spacing="15.0">
                        <!-- Stock Bajo -->
                        <Pane styleClass="card" stylesheets="@css/panel-productos.css" prefHeight="190.0" prefWidth="880.0">
                           <children>
                              <Label layoutX="25.0" layoutY="15.0" text="⚠️ Productos Bajo Stock" textFill="#274f8d">
                                 <font>
                                    <Font name="Arial Black" size="14.0" />
                                 </font>
                              </Label>
                              <Label fx:id="lblBajoStockCount" layoutX="25.0" layoutY="55.0" text="0 productos" textFill="#1f2a3a">
                                 <font>
                                    <Font name="Arial" size="24.0" />
                                 </font>
                              </Label>
                              <Label layoutX="25.0" layoutY="110.0" text="Requieren reabastecimiento inmediato" textFill="#607399">
                                 <font>
                                    <Font name="Arial" size="11.0" />
                                 </font>
                              </Label>
                           </children>
                        </Pane>

                          <!-- Ventas por Usuario -->
                          <Pane styleClass="card" stylesheets="@css/panel-productos.css" prefHeight="190.0" prefWidth="880.0">
                             <children>
                                <Label layoutX="25.0" layoutY="15.0" text="Ventas por Usuario" textFill="#274f8d">
                                   <font>
                                      <Font name="Arial Black" size="14.0" />
                                   </font>
                                </Label>
                                <VBox fx:id="vboxVentasUsuarios" layoutX="25.0" layoutY="50.0" prefHeight="120.0" prefWidth="830.0" spacing="8.0">
                                   <children>
                                      <!-- Aquí se cargarán dinámicamente los items por usuario -->
                                   </children>
                                </VBox>
                             </children>
                          </Pane>

                        <!-- Estadísticas Generales -->
                        <Pane styleClass="card" stylesheets="@css/panel-productos.css" prefHeight="190.0" prefWidth="880.0">
                           <children>
                              <Label layoutX="25.0" layoutY="15.0" text="Resumen General" textFill="#274f8d">
                                 <font>
                                    <Font name="Arial Black" size="14.0" />
                                 </font>
                              </Label>
                              <HBox layoutX="25.0" layoutY="55.0" prefHeight="115.0" prefWidth="830.0" spacing="40.0">
                                 <children>
                                    <VBox spacing="5.0">
                                       <children>
                                          <Label text="Categorías Activas" textFill="#607399">
                                             <font>
                                                <Font name="Arial" size="11.0" />
                                             </font>
                                          </Label>
                                          <Label fx:id="lblCategorias" text="0" textFill="#274f8d">
                                             <font>
                                                <Font name="Arial Black" size="20.0" />
                                             </font>
                                          </Label>
                                       </children>
                                    </VBox>
                                    <VBox spacing="5.0">
                                       <children>
                                          <Label text="Platillos Activos" textFill="#607399">
                                             <font>
                                                <Font name="Arial" size="11.0" />
                                             </font>
                                          </Label>
                                          <Label fx:id="lblPlatillos" text="0" textFill="#274f8d">
                                             <font>
                                                <Font name="Arial Black" size="20.0" />
                                             </font>
                                          </Label>
                                       </children>
                                    </VBox>
                                    <VBox spacing="5.0">
                                       <children>
                                          <Label text="Productos Activos" textFill="#607399">
                                             <font>
                                                <Font name="Arial" size="11.0" />
                                             </font>
                                          </Label>
                                          <Label fx:id="lblProductos" text="0" textFill="#274f8d">
                                             <font>
                                                <Font name="Arial Black" size="20.0" />
                                             </font>
                                          </Label>
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                           </children>
                        </Pane>
                     </VBox>
                  </HBox>

                  <!-- BOTTOM SECTION: VENTAS POR PERÍODO -->
                  <Label layoutX="40.0" layoutY="730.0" styleClass="subtitle" text="Detalles Adicionales" textFill="#607399">
                     <font>
                        <Font name="Arial Black" size="18.0" />
                     </font>
                  </Label>

                  <Pane layoutX="40.0" layoutY="770.0" prefHeight="300.0" prefWidth="1800.0" styleClass="card" stylesheets="@css/panel-productos.css">
                     <children>
                        <Label layoutX="25.0" layoutY="15.0" text="Historial de Estadísticas" textFill="#274f8d">
                           <font>
                              <Font name="Arial Black" size="16.0" />
                           </font>
                        </Label>
                        <VBox fx:id="vboxHistorial" layoutX="25.0" layoutY="55.0" prefHeight="230.0" prefWidth="1750.0" spacing="10.0">
                           <children>
                              <!-- Se cargarán dinámicamente -->
                           </children>
                        </VBox>
                     </children>
                  </Pane>
               </children>
            </Pane>
         </content>
      </ScrollPane>
   </children>
</AnchorPane>
