<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="Infinity" maxWidth="Infinity" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistema.puntoventas.controller.PanelPrincipalEstadisticasController">
   <children>
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 0;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <content>
            <VBox spacing="20.0" styleClass="panel-root" stylesheets="@css/panel-productos.css">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>

                  <Label styleClass="title" text="Panel de Control y Auditoría">
                     <font>
                        <Font name="Arial" size="28.0" />
                     </font>
                  </Label>

                  <HBox spacing="20.0">
                     <children>
                        <Pane prefHeight="130.0" styleClass="card-kpi-blue" stylesheets="@css/PanelPrincipalVista.css" HBox.hgrow="ALWAYS">
                           <children>
                              <Label layoutX="25.0" layoutY="15.0" text="Ingresos Brutos" textFill="WHITE">
                                 <font><Font name="Arial" size="14.0" /></font>
                              </Label>
                              <Label fx:id="lblIngresosTotales" layoutX="25.0" layoutY="45.0" text="₡0.00" textFill="WHITE">
                                 <font><Font name="Arial" size="32.0" /></font>
                              </Label>
                              <Label layoutX="25.0" layoutY="100.0" text="Total de ventas del periodo" textFill="#dbeafe" />
                           </children>
                        </Pane>
                        <Pane prefHeight="130.0" styleClass="card-kpi-green" stylesheets="@css/PanelPrincipalVista.css" HBox.hgrow="ALWAYS">
                           <children>
                              <Label layoutX="25.0" layoutY="15.0" text="Utilidad Real" textFill="WHITE">
                                 <font><Font name="Arial" size="14.0" /></font>
                              </Label>
                              <Label fx:id="lblUtilidadNeta" layoutX="25.0" layoutY="45.0" text="₡0.00" textFill="WHITE">
                                 <font><Font name="Arial" size="32.0" /></font>
                              </Label>
                              <Label layoutX="25.0" layoutY="100.0" text="Ganancia neta calculada" textFill="#dcfce7" />
                           </children>
                        </Pane>
                        <Pane prefHeight="130.0" styleClass="card-kpi-yellow" stylesheets="@css/PanelPrincipalVista.css" HBox.hgrow="ALWAYS">
                           <children>
                              <Label layoutX="25.0" layoutY="15.0" text="Ticket Promedio" textFill="WHITE">
                                 <font><Font name="Arial" size="14.0" /></font>
                              </Label>
                              <Label fx:id="lblTicketPromedio" layoutX="25.0" layoutY="45.0" text="₡0.00" textFill="WHITE">
                                 <font><Font name="Arial" size="32.0" /></font>
                              </Label>
                              <Label layoutX="25.0" layoutY="100.0" text="Promedio por transacción" textFill="#fef9c3" />
                           </children>
                        </Pane>
                        <Pane prefHeight="130.0" styleClass="card-kpi-red" stylesheets="@css/PanelPrincipalVista.css" HBox.hgrow="ALWAYS">
                           <children>
                              <Label layoutX="25.0" layoutY="15.0" text="Pérdidas de Inventario" textFill="WHITE">
                                 <font><Font name="Arial" size="14.0" /></font>
                              </Label>
                              <Label fx:id="lblPerdidasTotales" layoutX="25.0" layoutY="45.0" text="₡0.00" textFill="WHITE">
                                 <font><Font name="Arial" size="32.0" /></font>
                              </Label>
                              <Label layoutX="25.0" layoutY="100.0" text="Mermas y ajustes manuales" textFill="#fee2e2" />
                           </children>
                        </Pane>
                     </children>
                  </HBox>

                  <Label styleClass="subtitle" text="Análisis Predictivo y Reabastecimiento" textFill="#607399">
                     <font>
                        <Font name="Arial" size="18.0" />
                     </font>
                  </Label>

                  <HBox spacing="20.0">
                     <children>
                        <VBox spacing="10.0" styleClass="card" stylesheets="@css/panel-productos.css" HBox.hgrow="ALWAYS" prefWidth="600.0">
                           <padding>
                              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                           </padding>
                           <children>
                              <Label text="Productos con Riesgo de Stock" textFill="#274f8d">
                                 <font><Font name="Arial" size="16.0" /></font>
                              </Label>
                              <TableView fx:id="tablePrediccionStock" prefHeight="330.0" VBox.vgrow="ALWAYS">
                                 <columns>
                                    <TableColumn fx:id="colNombre" prefWidth="200.0" text="Producto" />
                                    <TableColumn fx:id="colStockActual" prefWidth="80.0" text="Stock" />
                                    <TableColumn fx:id="colDiasRestantes" prefWidth="120.0" text="Días Estimados" />
                                    <TableColumn fx:id="colIndiceRiesgo" prefWidth="150.0" text="Nivel de Riesgo" />
                                    <TableColumn fx:id="colSugerenciaCompra" prefWidth="200.0" text="Acción Recomendada" />
                                 </columns>
                              </TableView>
                           </children>
                        </VBox>

                        <VBox spacing="20.0" prefWidth="400.0">
                           <children>
                              <VBox spacing="10.0" styleClass="card" stylesheets="@css/panel-productos.css" VBox.vgrow="ALWAYS">
                                 <padding>
                                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                 </padding>
                                 <children>
                                    <Label text="Rendimiento por Vendedor" textFill="#274f8d">
                                       <font><Font name="Arial" size="14.0" /></font>
                                    </Label>
                                    <Pane fx:id="vboxVentasUsuarios" prefHeight="120.0" VBox.vgrow="ALWAYS" />
                                 </children>
                              </VBox>

                              <VBox spacing="10.0" styleClass="card" stylesheets="@css/panel-productos.css" VBox.vgrow="ALWAYS">
                                 <padding>
                                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                 </padding>
                                 <children>
                                    <Label text="Ranking de productos más vendidos" textFill="#274f8d">
                                       <font><Font name="Arial" size="14.0" /></font>
                                    </Label>
                                    <TableView fx:id="tableRankingProductos" prefHeight="150.0" VBox.vgrow="ALWAYS">
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                       </columnResizePolicy>
                                       <columns>
                                          <TableColumn fx:id="colRankingProducto" prefWidth="200.0" text="Producto" />
                                          <TableColumn fx:id="colRankingCantidad" prefWidth="100.0" text="Vendidos" />
                                       </columns>
                                    </TableView>
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <Label styleClass="subtitle" text="Auditoría de Sistema y Alertas Críticas" textFill="#607399">
                     <font>
                        <Font name="Arial" size="18.0" />
                     </font>
                  </Label>

                  <VBox spacing="10.0" styleClass="card" stylesheets="@css/panel-productos.css">
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                     <children>
                        <Label text="Registro de Actividad Reciente" textFill="#274f8d">
                           <font><Font name="Arial" size="16.0" /></font>
                        </Label>
                        <Label text="Monitoreo de ventas e inventario recientes" textFill="#94a3b8">
                           <font><Font size="12.0" /></font>
                        </Label>
                        <TableView fx:id="tableActividadReciente" prefHeight="250.0" VBox.vgrow="ALWAYS">
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                           <columns>
                              <TableColumn fx:id="colActividadReciente" prefWidth="800.0" text="Actividad" />
                           </columns>
                        </TableView>
                     </children>
                  </VBox>

               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</AnchorPane>
