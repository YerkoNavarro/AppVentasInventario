<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistema.puntoventas.controller.PanelPrincipalVistaController">
    <children>
        <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <left>
                <VBox prefWidth="260.0" spacing="10.0" styleClass="sidebar" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="30.0" />
                    </padding>
                    <children>
                        <Label styleClass="logo-label" text="PELIO CLONE" />

                        <VBox spacing="5.0">
                            <children>
                                <Button fx:id="btnUsuarios" styleClass="menu-button" text="Usuarios" maxWidth="Infinity">
                                    <graphic>
                                        <Label style="-fx-background-color: #6366f1;" styleClass="icon-circle" text="U" />
                                    </graphic>
                                </Button>
                                <Button fx:id="btnProductos" styleClass="menu-button, menu-button-active" text="Productos" maxWidth="Infinity">
                                    <graphic>
                                        <Label style="-fx-background-color: #0ea5e9;" styleClass="icon-circle" text="P" />
                                    </graphic>
                                </Button>
                                <Button fx:id="btnVentas" styleClass="menu-button" text="Ventas" maxWidth="Infinity">
                                    <graphic>
                                        <Label style="-fx-background-color: #22c55e;" styleClass="icon-circle" text="V" />
                                    </graphic>
                                </Button>
                                <Button fx:id="btnInventario" styleClass="menu-button" text="Inventario" maxWidth="Infinity">
                                    <graphic>
                                        <Label style="-fx-background-color: #f59e0b;" styleClass="icon-circle" text="I" />
                                    </graphic>
                                </Button>
                            </children>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />

                        <Button styleClass="menu-button" text="Configuración" maxWidth="Infinity">
                            <graphic>
                                <Label style="-fx-background-color: #9ca3af;" styleClass="icon-circle" text="C" />
                            </graphic>
                        </Button>
                    </children>
                </VBox>
            </left>

            <center>
                <StackPane fx:id="contentArea" style="-fx-background-color: #f9fafb;">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                </StackPane>
            </center>
        </BorderPane>
    </children>
</AnchorPane>