<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" stylesheets="@css/PanelPrincipalVista.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistema.puntoventas.controller.PanelPrincipalVistaController">
    <children>
        <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <left>
                <VBox prefWidth="260.0" spacing="10.0" styleClass="sidebar" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="30.0" />
                    </padding>
                    <children>
                        <Label styleClass="logo-label" text="Eluney" />

                        <VBox spacing="5.0">
                            <children>
                                <Button fx:id="btnUsuarios" maxWidth="Infinity" styleClass="menu-button" text="Usuarios">
                                    <graphic>
                                        <Label style="-fx-background-color: #6366f1;" styleClass="icon-circle" text="U" />
                                    </graphic>
                                </Button>
                                <Button fx:id="btnProductos" maxWidth="Infinity" styleClass="menu-button, menu-button-active" text="Productos">
                                    <graphic>
                                        <Label style="-fx-background-color: #0ea5e9;" styleClass="icon-circle" text="P" />
                                    </graphic>
                                </Button>
                                <Button fx:id="btnVentas" maxWidth="Infinity" styleClass="menu-button" text="Ventas">
                                    <graphic>
                                        <Label style="-fx-background-color: #22c55e;" styleClass="icon-circle" text="V" />
                                    </graphic>
                                </Button>
                                <Button fx:id="btnInventario" maxWidth="Infinity" prefWidth="219.0" styleClass="menu-button" text="Inventario">
                                    <graphic>
                                        <Label style="-fx-background-color: #f59e0b;" styleClass="icon-circle" text="I" />
                                    </graphic>
                                </Button>
                        <Button fx:id="btnPlatillos" layoutX="10.0" layoutY="171.0" maxWidth="Infinity" prefWidth="219.0" styleClass="menu-button" text="Platillos">
                           <graphic>
                              <Label style="-fx-background-color: #C11C84;" styleClass="icon-circle" text="I" />
                           </graphic>
                        </Button>
                            </children>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />

                        <Button maxWidth="Infinity" styleClass="menu-button" text="Configuración">
                            <graphic>
                                <Label style="-fx-background-color: pink;" styleClass="icon-circle" text="C" />
                            </graphic>
                        </Button>
                    </children>
                </VBox>
            </left>

            <center>
                <StackPane fx:id="contentArea" style="-fx-background-color: #f1f5f9;" />
            </center>

        </BorderPane>
    </children>
</AnchorPane>
