                                        <Font name="Arial Black" size="12.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblUsuariosActivos" layoutX="69.0" layoutY="66.0" styleClass="label-metrica" stylesheets="@css/panel-productos.css" />
                            </children>
                        </Pane>
                        <Pane fx:id="CardUsuariosAdmin" layoutX="10.0" layoutY="10.0" prefHeight="200.0" prefWidth="200.0" styleClass="card-kpi-green" stylesheets="@css/PanelPrincipalVista.css">
                            <children>
                                <Label layoutX="38.0" layoutY="29.0" text="Usuarios admin" textFill="WHITE">
                                    <font>
                                        <Font name="Arial Black" size="12.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblUsuariosAdmin" layoutX="70.0" layoutY="66.0" styleClass="label-metrica" />
                            </children>
                        </Pane>
                        <Pane fx:id="CardUsuariosVendedor" layoutX="210.0" layoutY="10.0" prefHeight="132.0" prefWidth="206.0" styleClass="card-kpi-yellow" stylesheets="@css/PanelPrincipalVista.css">
