                                    <font>
                                        <Font name="Arial Black" size="12.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblUsuariosVendedor" layoutX="73.0" layoutY="66.0" styleClass="label-metrica" />
                            </children>
                        </Pane>
                    </children>
                </HBox>
                <Button fx:id="btnEditarUsuario" layoutX="281.0" layoutY="224.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="151.0" styleClass="btn-primary" stylesheets="@css/panel-productos.css" text="Editar Usuario" />
