                <Button id="btnAgregarProducto" fx:id="btnAgregarUsuario" layoutX="42.0" layoutY="224.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="151.0" styleClass="btn-primary" stylesheets="@css/panel-productos.css" text="Agregar Usuario" />
