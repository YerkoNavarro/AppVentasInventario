<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="1080.0" prefWidth="1920.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistema.puntoventas.controller.PanelPrincipalUsuariosController">
    <children>
        <Pane id="panePrinc" fx:id="contenedorTabla" prefHeight="827.0" prefWidth="1675.0" styleClass="panel-root" stylesheets="@css/panel-productos.css">
            <children>
                <TableView fx:id="tableUsuarios" layoutX="42.0" layoutY="284.0" prefHeight="456.0" prefWidth="916.0">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="63.200016021728516" text="id" />
                        <TableColumn fx:id="colNombre" prefWidth="129.5999755859375" text="Nombre " />
                        <TableColumn fx:id="colApellido" prefWidth="108.79997253417969" text="Apellido" />
                        <TableColumn fx:id="colRut" prefWidth="112.79998779296875" text="Rut" />
                        <TableColumn fx:id="colContraseña" prefWidth="143.99993896484375" text="Contraseña" />
                        <TableColumn fx:id="colTelefono" prefWidth="128.800048828125" text="Telefono " />
                        <TableColumn fx:id="colRol" prefWidth="104.0" text="Rol" />
                        <TableColumn fx:id="colEstado" prefWidth="119.199951171875" text="Estado" />

                    </columns>
                </TableView>
                <HBox layoutX="42.0" layoutY="24.0" prefHeight="132.0" prefWidth="936.0" spacing="40.0">
                    <children>
                        <Pane fx:id="CardUsuariosActivos" prefHeight="200.0" prefWidth="200.0" styleClass="card-kpi-blue" stylesheets="@css/PanelPrincipalVista.css">
