<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="900.0" prefWidth="1400.0" stylesheets="@css/PanelPrincipalVista.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistema.puntoventas.controller.DashboardVistaController">
    <children>
        <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <center>
                <ScrollPane fitToWidth="true" style="-fx-background-color: #FFF5EB; -fx-border-color: transparent;">
                    <content>
                        <StackPane fx:id="contentArea" style="-fx-background-color: #FFF5EB;">
                            <VBox spacing="25.0" style="-fx-padding: 40;">

                                <VBox spacing="5.0">
                                    <Label style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #3E2723;" text="Dashboard" />
                                    <Label style="-fx-font-size: 16px; -fx-text-fill: #8D6E63;" text="Resumen general de las actividades del sistema" />
                                </VBox>

                                <HBox spacing="25.0">
                                    <VBox prefHeight="140.0" styleClass="card-kpi-coffee" HBox.hgrow="ALWAYS">
                                        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 25;">
                                            <Label style="-fx-text-fill: white; -fx-font-size: 40px;" text="🛒" />
                                            <VBox>
                                                <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-opacity: 0.9;" text="Ventas" />
                                                <Label fx:id="lblTotalCompras" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;" text="0" />
                                            </VBox>
                                        </HBox>
                                    </VBox>

                                    <VBox prefHeight="140.0" styleClass="card-kpi-caramel" HBox.hgrow="ALWAYS">
                                        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 25;">
                                            <Label style="-fx-text-fill: white; -fx-font-size: 40px;" text="📦" />
                                            <VBox>
                                                <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-opacity: 0.9;" text="Productos" />
                                                <Label fx:id="lblTotalProductos" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;" text="0" />
                                            </VBox>
                                        </HBox>
                                    </VBox>

                                    <VBox prefHeight="140.0" styleClass="card-kpi-latte" HBox.hgrow="ALWAYS">
                                        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 25;">
                                            <Label style="-fx-text-fill: white; -fx-font-size: 40px;" text="👥" />
                                            <VBox>
                                                <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-opacity: 0.9;" text="Usuarios" />
                                                <Label fx:id="lblTotalUsuarios" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;" text="0" />
                                            </VBox>
                                        </HBox>
                                    </VBox>
                                </HBox>

                                <GridPane hgap="25.0" vgap="25.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                                    </columnConstraints>
                                    <children>
                                        <VBox onMouseClicked="#abrirModuloDashboard" alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(44,24,16,0.06), 12, 0, 0, 4); -fx-padding: 30; -fx-cursor: hand;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                            <Label style="-fx-font-size: 40px; -fx-text-fill: #D4893B;" text="⏱️" />
                                            <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #3E2723;" text="Dashboard" />
                                            <Label alignment="CENTER" style="-fx-text-fill: #8D6E63; -fx-font-size: 13px;" text="Resumen de métricas y estadísticas." textAlignment="CENTER" wrapText="true" />
                                        </VBox>
                                        <VBox onMouseClicked="#abrirModuloOrdenes" alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(44,24,16,0.06), 12, 0, 0, 4); -fx-padding: 30; -fx-cursor: hand;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                            <Label style="-fx-font-size: 40px; -fx-text-fill: #D4893B;" text="🛒" />
                                            <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #3E2723;" text="Órdenes" />
                                            <Label alignment="CENTER" style="-fx-text-fill: #8D6E63; -fx-font-size: 13px;" text="Gestión de ventas y pedidos." textAlignment="CENTER" wrapText="true" />
                                        </VBox>
                                        <VBox onMouseClicked="#abrirModuloProductos" alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(44,24,16,0.06), 12, 0, 0, 4); -fx-padding: 30; -fx-cursor: hand;" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                            <Label style="-fx-font-size: 40px; -fx-text-fill: #D4893B;" text="📦" />
                                            <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #3E2723;" text="Productos" />
                                            <Label alignment="CENTER" style="-fx-text-fill: #8D6E63; -fx-font-size: 13px;" text="Control total de inventario." textAlignment="CENTER" wrapText="true" />
                                        </VBox>
                                        <VBox onMouseClicked="#abrirModuloCategorias" alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(44,24,16,0.06), 12, 0, 0, 4); -fx-padding: 30; -fx-cursor: hand;" GridPane.columnIndex="3" GridPane.rowIndex="0">
                                            <Label style="-fx-font-size: 40px; -fx-text-fill: #D4893B;" text="🏷️" />
                                            <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #3E2723;" text="Categorías" />
                                            <Label alignment="CENTER" style="-fx-text-fill: #8D6E63; -fx-font-size: 13px;" text="Organización por rubros." textAlignment="CENTER" wrapText="true" />
                                        </VBox>
                                        <VBox onMouseClicked="#abrirModuloUsuarios" alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(44,24,16,0.06), 12, 0, 0, 4); -fx-padding: 30; -fx-cursor: hand;" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                            <Label style="-fx-font-size: 40px; -fx-text-fill: #D4893B;" text="👥" />
                                            <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #3E2723;" text="Usuarios" />
                                            <Label alignment="CENTER" style="-fx-text-fill: #8D6E63; -fx-font-size: 13px;" text="Administración de cuentas." textAlignment="CENTER" wrapText="true" />
                                        </VBox>
                                        <VBox onMouseClicked="#abrirModuloReportes" alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(44,24,16,0.06), 12, 0, 0, 4); -fx-padding: 30; -fx-cursor: hand;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                            <Label style="-fx-font-size: 40px; -fx-text-fill: #D4893B;" text="📊" />
                                            <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #3E2723;" text="Reportes" />
                                            <Label alignment="CENTER" style="-fx-text-fill: #8D6E63; -fx-font-size: 13px;" text="Informes financieros detallados." textAlignment="CENTER" wrapText="true" />
                                        </VBox>
                                        <VBox onMouseClicked="#abrirModuloPerfil" alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(44,24,16,0.06), 12, 0, 0, 4); -fx-padding: 30; -fx-cursor: hand;" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                            <Label style="-fx-font-size: 40px; -fx-text-fill: #D4893B;" text="👤" />
                                            <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #3E2723;" text="Perfil" />
                                            <Label alignment="CENTER" style="-fx-text-fill: #8D6E63; -fx-font-size: 13px;" text="Ajustes de datos personales." textAlignment="CENTER" wrapText="true" />
                                        </VBox>
                                        <VBox onMouseClicked="#abrirModuloTienda" alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(44,24,16,0.06), 12, 0, 0, 4); -fx-padding: 30; -fx-cursor: hand;" GridPane.columnIndex="3" GridPane.rowIndex="1">
                                            <Label style="-fx-font-size: 40px; -fx-text-fill: #D4893B;" text="🏪" />
                                            <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #3E2723;" text="Tienda" />
                                            <Label alignment="CENTER" style="-fx-text-fill: #8D6E63; -fx-font-size: 13px;" text="Vista pública de la tienda." textAlignment="CENTER" wrapText="true" />
                                        </VBox>
                                    </children>
                                    <rowConstraints>
                                        <RowConstraints />
                                        <RowConstraints />
                                    </rowConstraints>
                                </GridPane>

                            </VBox>
                        </StackPane>
                    </content>
                </ScrollPane>
            </center>

        </BorderPane>
    </children>
</AnchorPane>
