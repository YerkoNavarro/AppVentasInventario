         <children>
            <TableView fx:id="tableProductos" layoutX="42.0" layoutY="284.0" prefHeight="316.0" prefWidth="1149.0">
              <columns>
                <TableColumn fx:id="colId" prefWidth="63.200016021728516" text="id" />
                <TableColumn fx:id="colNombre" prefWidth="129.5999755859375" text="nombre " />
                  <TableColumn fx:id="colPrecioCompra" prefWidth="108.79997253417969" text="precio compra" />
                  <TableColumn fx:id="colPrecioVenta" prefWidth="112.79998779296875" text="precio venta" />
