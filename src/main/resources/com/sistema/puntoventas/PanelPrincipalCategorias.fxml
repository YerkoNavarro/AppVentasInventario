<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="Infinity" maxWidth="Infinity" styleClass="panel-root" stylesheets="@css/panel-productos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistema.puntoventas.controller.moduloProductos.PanelPrincipalCategoriasController">
    <children>
        <HBox spacing="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Pane fx:id="CardProductos" prefHeight="132.0" prefWidth="200.0" styleClass="card-kpi-blue" stylesheets="@css/PanelPrincipalVista.css" HBox.hgrow="ALWAYS">
                    <children>
                        <Label layoutX="40.0" layoutY="30.0" text="Productos activos" textFill="#f7f4f4">
                            <font><Font name="Arial Black" size="12.0" /></font>
                        </Label>
                        <Label fx:id="lblProductosActivos" layoutX="69.0" layoutY="66.0" styleClass="label-metrica" stylesheets="@css/panel-productos.css" />
                    </children>
                </Pane>
                <Pane fx:id="CardCategorias" prefHeight="132.0" prefWidth="200.0" styleClass="card-kpi-green" stylesheets="@css/PanelPrincipalVista.css" HBox.hgrow="ALWAYS">
                    <children>
                        <Label layoutX="38.0" layoutY="29.0" text="Categorias activas" textFill="WHITE">
                            <font><Font name="Arial Black" size="12.0" /></font>
                        </Label>
                        <Label fx:id="lblCategoriasActivas" layoutX="70.0" layoutY="66.0" styleClass="label-metrica" />
                    </children>
                </Pane>
                <Pane fx:id="CardActivos" prefHeight="132.0" prefWidth="200.0" styleClass="card-kpi-yellow" stylesheets="@css/PanelPrincipalVista.css" HBox.hgrow="ALWAYS">
                    <children>
                        <Label layoutX="47.0" layoutY="32.0" text="Platillos activos" textFill="WHITE">
                            <font><Font name="Arial Black" size="12.0" /></font>
                        </Label>
                        <Label fx:id="lblPlatillosActivos" layoutX="73.0" layoutY="66.0" styleClass="label-metrica" />
                    </children>
                </Pane>
                <Pane fx:id="CardBajoStock" prefHeight="132.0" prefWidth="200.0" styleClass="card-kpi-red" stylesheets="@css/PanelPrincipalVista.css" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="cardBajoStock" layoutX="33.0" layoutY="32.0" text="Productos bajo Stock" textFill="WHITE">
                            <font><Font name="Arial Black" size="12.0" /></font>
                        </Label>
                        <Label fx:id="lblBajoStock" layoutX="73.0" layoutY="66.0" styleClass="label-metrica" />
                    </children>
                </Pane>
            </children>
        </HBox>

        <HBox spacing="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="170.0">
            <children>
                <Button id="btnAgregarProducto" fx:id="btnAgregarProducto" mnemonicParsing="false" prefHeight="35.0" prefWidth="151.0" styleClass="btn-primary" stylesheets="@css/panel-productos.css" text="Agregar Categoria" />
                <Button fx:id="btnEditarProducto" mnemonicParsing="false" prefHeight="35.0" prefWidth="151.0" styleClass="btn-primary" stylesheets="@css/panel-productos.css" text="Editar Categoria" />
                <Button fx:id="btnEliminarProducto" mnemonicParsing="false" prefHeight="35.0" prefWidth="151.0" styleClass="btn-primary" stylesheets="@css/panel-productos.css" text="Eliminar Categoria" />

                <Pane HBox.hgrow="ALWAYS" />

                <Button fx:id="btnVerPlatillos" managed="false" mnemonicParsing="false" prefHeight="35.0" prefWidth="151.0" styleClass="btn-primary" stylesheets="@css/panel-productos.css" text="Ver platillos" visible="false" />
            </children>
        </HBox>

        <TableView fx:id="tableProductos" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="220.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="100.0" text="ID" />
                <TableColumn fx:id="colCategoria" prefWidth="0.0" text="categoria" visible="false" />
                <TableColumn fx:id="colNombre" prefWidth="180.0" text="nombre" />
                <TableColumn fx:id="colDescripcion" prefWidth="250.0" text="descripción" />
                <TableColumn fx:id="colActiva" prefWidth="170.0" text="activa" />
            </columns>
        </TableView>
    </children>
</AnchorPane>